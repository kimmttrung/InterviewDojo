{
  "dependencies": {
    "@nestjs/mapped-types": "*"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "prepare": "husky"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "npm --prefix backend run lint",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "npm --prefix frontend run lint",
      "prettier --write"
    ]
  }
}
