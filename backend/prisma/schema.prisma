generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"] // Hỗ trợ Full-text search đã bàn
}

datasource db {
  provider = "postgresql"
}

// --- NGƯỜI DÙNG & VAI TRÒ ---

model User {
  id              Int            @id @default(autoincrement())
  email           String         @unique
  password        String
  name            String?
  bio             String?
  role            String         @default("candidate") // candidate | admin
  status          String         @default("offline")
  avatarUrl       String?        @map("avatar_url")
  experienceYears Int            @default(0) @map("experience_years")
  creditBalance   Float          @default(0.0) @map("credit_balance")
  createdAt       DateTime       @default(now()) @map("created_at")

  // Quan hệ với TargetRole (One-to-Many)
  targetRoleId    Int?           @map("target_role_id")
  targetRole      TargetRole?    @relation(fields: [targetRoleId], references: [id])

  // Quan hệ khác
  skills          UserSkill[]
  savedQuestions  UserQuestion[]
  feedbacksGotten Feedback[]     @relation("RevieweeFeedbacks")
  feedbacksGiven  Feedback[]     @relation("ReviewerFeedbacks")
  isInterviewed   MockSession[]  @relation("IntervieweeSessions")
  interviews      MockSession[]  @relation("InterviewerSessions")

  @@map("users")
}

model TargetRole {
  id          Int                  @id @default(autoincrement())
  name        String               @unique
  users       User[]
  questions   TargetRoleQuestion[]

  @@map("target_roles")
}

// --- CÂU HỎI & PHÂN LOẠI ---

model Question {
  id           Int       @id @default(autoincrement())
  title        String
  slug         String    @unique
  difficulty   String    // Easy | Medium | Hard
  isPublished  Boolean   @default(false) @map("is_published")
  data         Json      // Chứa content, snippets, hints, test_cases...
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Quan hệ Many-to-Many
  categories   CategoryQuestion[]
  targetRoles  TargetRoleQuestion[]
  companies    QuestionCompany[]
  
  // Quan hệ khác
  sessions     MockSession[]
  savedByUsers UserQuestion[]

  @@map("questions")
}

model Category {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  description String?
  questions   CategoryQuestion[]

  @@map("categories")
}

// --- BẢNG TRUNG GIAN (COMPOSITE KEYS) ---

model CategoryQuestion {
  questionId Int @map("question_id")
  categoryId Int @map("category_id")

  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([questionId, categoryId]) // Composite Primary Key
  @@map("category_question")
}

model TargetRoleQuestion {
  targetRoleId Int @map("target_role_id")
  questionId   Int @map("question_id")

  targetRole   TargetRole @relation(fields: [targetRoleId], references: [id], onDelete: Cascade)
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([targetRoleId, questionId]) // Composite Primary Key
  @@map("target_role_question")
}

model UserQuestion {
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  savedAt    DateTime @default(now()) @map("saved_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([userId, questionId]) // Composite Primary Key (ngăn save trùng)
  @@map("user_questions")
}

// --- CÔNG TY & KỸ NĂNG ---

model Company {
  id        Int               @id @default(autoincrement())
  name      String            @unique
  logoUrl   String?           @map("logo_url")
  questions QuestionCompany[]

  @@map("companies")
}

model QuestionCompany {
  questionId Int @map("question_id")
  companyId  Int @map("company_id")

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([questionId, companyId])
  @@map("question_companies")
}

model Skill {
  id       Int         @id @default(autoincrement())
  name     String      @unique
  category String?     // Technical | Soft Skill
  users    UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId  Int   @map("user_id")
  skillId Int   @map("skill_id")
  score   Float @default(0)

  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

// --- PHỎNG VẤN & PHÂN TÍCH ---

model MockSession {
  id              Int      @id @default(autoincrement())
  interviewerId   Int      @map("interviewer_id")
  intervieweeId   Int      @map("interviewee_id")
  questionId      Int      @map("question_id")
  scheduledAt     DateTime @default(now()) @map("scheduled_at")
  durationMinutes Int      @map("duration_minutes")
  status          String   @default("scheduled") // scheduled | ongoing | completed | cancelled
  recordingUrl    String?  @map("recording_url")
  meetingLink     String?  @map("meeting_link")

  aiAnalysis      AiAnalysis?
  feedbacks       Feedback[]
  interviewee     User        @relation("IntervieweeSessions", fields: [intervieweeId], references: [id])
  interviewer     User        @relation("InterviewerSessions", fields: [interviewerId], references: [id])
  question        Question    @relation(fields: [questionId], references: [id])

  @@map("mock_sessions")
}

model Feedback {
  id             Int      @id @default(autoincrement())
  sessionId      Int      @map("session_id")
  reviewerId     Int      @map("reviewer_id")
  revieweeId     Int      @map("reviewee_id")
  communication  Int      // 1-5
  technical      Int      // 1-5
  problemSolving Int      @map("problem_solving") // 1-5
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at")

  reviewee       User        @relation("RevieweeFeedbacks", fields: [revieweeId], references: [id])
  reviewer       User        @relation("ReviewerFeedbacks", fields: [reviewerId], references: [id])
  session        MockSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

model AiAnalysis {
  id           Int      @id @default(autoincrement())
  sessionId    Int      @unique @map("session_id")
  transcript   String?
  strengths    Json?    // Array of strings
  weaknesses   Json?    // Array of strings
  suggestions  Json?    // Array of strings
  overallScore Float    @map("overall_score")
  processedAt  DateTime @default(now()) @map("processed_at")
  session      MockSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("ai_analyses")
}

enum Role {
  CANDIDATE
  ADMIN
}
