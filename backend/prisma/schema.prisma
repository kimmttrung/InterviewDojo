generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  CANDIDATE
  MENTOR
  ADMIN
}

enum SlotStatus {
  AVAILABLE
  BLOCKED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SlotRecurrentType {
  NONE
  WEEKLY
  MONTHLY
  YEARLY
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  SYSTEM_DESIGN
  BEHAVIORAL
  TECHNICAL
  CODING
}

enum SubmissionStatus {
  PENDING
  COMPILING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILE_ERROR
}

enum SkillType {
  SOFTSKILL
  HARDSKILL
  LANGUAGE
}

enum SkillLevel {
  LEARNING
  PRACTICED
  PERSONAL_PROJECT
  PRODUCTION_READY
  EXPERT
}

enum SessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum ApprovalStatus {
  INCOMPLETE
  ACTIVE
  PENDING
  REJECTED
  SUSPENDED
}

enum CoachingQuestionType {
  TEXT
  FILE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  EXPIRED
}

enum MatchStatus {
  WAITING
  MATCHED
  CANCELLED
  EXPIRED
  REJECTED
  COMPLETED
}

enum MatchStrategy {
  RANDOM
  SKILL
  RATING
}

enum PaymentProvider {
  VNPAY
  MOMO
  STRIPE
  PAYPAL
}

enum Currency {
  USD
  VND
  JPY
}

enum SessionSource {
  MENTOR_BOOKING
  P2P_MATCH
  SOLO
}

enum SessionMode {
  MEET
  SOLO
}

// ==================== USER & PROFILE ====================

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String
  name            String?
  bio             String?
  experienceYears Int      @default(0) @map("experience_years")
  avatarUrl       String?  @map("avatar_url")
  linkedInLink    String?  @map("linkedIn_link")
  githubLink      String?  @map("github_link")
  creditBalance   Float    @default(0.0) @map("credit_balance")
  role            Role     @default(CANDIDATE)
  status          UserStatus   @default(ACTIVE)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  targetRoleId    Int?     @map("target_role_id")

  targetRole        JobRole?         @relation("CandidateTargetRole", fields: [targetRoleId], references: [id])
  mentorProfile       MentorProfile?
  slots               Slot[]           @relation("MentorSlots")
  bookingsAsMentor     Booking[] @relation("MentorBookings")
  bookingsAsCandidate  Booking[] @relation("CandidateBookings")
  codeSubmissions     CodeSubmission[]
  skills              UserSkill[]
  bookmarks           UserBookmark[]
  mockSessions        MockSession[]    @relation("IntervieweeSessions")
  feedbacksGiven      Feedback[]       @relation("ReviewerFeedbacks")
  feedbacksReceived   Feedback[]       @relation("RevieweeFeedbacks")
  matchedAsCandidateA Match[] @relation("CandidateA")
  matchedAsCandidateB Match[] @relation("CandidateB")
  mentorApprovalLogs MentorApprovalLog[]
  bookingActionLogs  BookingActionLog[]

  @@map("users")
}

model MentorProfile {
  id                     Int      @id @default(autoincrement())
  userId                 Int      @unique @map("user_id")
  headline               String
  introductionVideoUrl   String?  @map("introdcution_video_url")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  approvalStatus ApprovalStatus @default(INCOMPLETE) @map("approval_status")
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences  Experience[]
  coachingPlans CoachingPlan[]
  approvalLogs MentorApprovalLog[]

  @@map("mentor_profiles")
}

model MentorApprovalLog {
  id           Int      @id @default(autoincrement())
  mentorId     Int      @map("mentor_id")
  adminId      Int      @map("admin_id")
  statusBefore String   @map("status_before")
  statusAfter  String   @map("status_after")
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")

  mentor MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  admin  User          @relation(fields: [adminId], references: [id])

  @@map("mentor_approval_logs")
}

// ==================== EXPERIENCE & COMPANY ====================

model Experience {
  id          Int       @id @default(autoincrement())
  mentorId    Int       @map("mentor_id")
  companyId   Int       @map("company_id")
  jobRoleId   Int       @map("job_role_id")
  description String?
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  isCurrent   Boolean   @default(false) @map("is_current")

  mentor MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  company Company       @relation(fields: [companyId], references: [id])
  jobRole JobRole       @relation(fields: [jobRoleId], references: [id])

  @@map("experiences")
}

model Company {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  logoUrl  String? @map("logo_url")
  industry String?

  experiences Experience[]
  questions   QuestionCompany[]

  @@map("companies")
}

model JobRole {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  experiences Experience[]
  questions   QuestionJobRole[]
  candidates  User[]            @relation("CandidateTargetRole")

  @@map("job_roles")
}

// ==================== SCHEDULING & BOOKING ====================

model Slot {
  id              Int                 @id @default(autoincrement())
  mentorId        Int                 @map("mentor_id")
  startTime       DateTime            @map("start_time")
  endTime         DateTime            @map("end_time")
  recurrentType   SlotRecurrentType   @default(NONE) @map("recurrent_type")
  recurrentUntil  DateTime?           @map("recurrent_until")
  status          SlotStatus          @default(AVAILABLE)
  createdAt       DateTime            @default(now()) @map("created_at")

  mentor   User      @relation("MentorSlots", fields: [mentorId], references: [id], onDelete: Cascade)
  booking  Booking?

  @@map("slots")
}

model Booking {
  id                         Int            @id @default(autoincrement())
  slotId                     Int            @unique @map("slot_id")
  mentorId                   Int            @map("mentor_id")
  candidateId                Int            @map("candidate_id")
  coachingPlanId            Int            @map("coaching_plan_id")

  snapshotPlanTitle          String         @map("snapshot_plan_title")
  snapshotPlanDescription    String?        @map("snapshot_plan_description")
  snapshotPlanPrice          Float?         @map("snapshot_plan_price")
  snapshotPlanDuration       Int?           @map("snapshot_plan_duration")

  status                     BookingStatus  @default(PENDING)

  createdAt                  DateTime       @default(now()) @map("created_at")

  slot          Slot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  mentor        User          @relation("MentorBookings", fields: [mentorId], references: [id])
  candidate     User          @relation("CandidateBookings", fields: [candidateId], references: [id])

  coachingPlan  CoachingPlan  @relation(fields: [coachingPlanId], references: [id])

  payments      Payment[]
  mockSessions  MockSession[]
  answers       CoachingPlanAnswer[]
  logs          BookingActionLog[]

  @@map("bookings")
}

model BookingActionLog {
  id            Int      @id @default(autoincrement())
  bookingId     Int      @map("booking_id")
  actorId       Int      @map("actor_id")
  statusBefore  String?  @map("status_before")
  statusAfter   String?  @map("status_after")
  action        String
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id])

  @@map("booking_action_logs")
}

model CoachingPlan {
  id          Int      @id @default(autoincrement())
  mentorId    Int      @map("mentor_id")
  title       String
  description String?
  duration    Int
  price       Float
  isActive    Boolean  @default(true) @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  mentor    MentorProfile          @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  questions CoachingPlanQuestion[]

  @@map("coaching_plans")
}

model CoachingPlanQuestion {
  id              Int                   @id @default(autoincrement())
  coachingPlanId  Int                   @map("coaching_plan_id")

  question        String
  type            CoachingQuestionType
  placeholder     String?

  isRequired      Boolean               @default(false) @map("is_required")
  orderIndex      Int                   @default(0) @map("order_index")

  createdAt       DateTime              @default(now()) @map("created_at")

  coachingPlan CoachingPlan @relation(fields: [coachingPlanId], references: [id], onDelete: Cascade)
  answers      CoachingPlanAnswer[]

  @@map("coaching_plan_questions")
}

model CoachingPlanAnswer {
  id          Int      @id @default(autoincrement())

  bookingId   Int      @map("booking_id")
  questionId  Int      @map("question_id")

  answerText  String?  @map("answer_text")
  fileUrl     String?  @map("file_url")

  createdAt   DateTime @default(now()) @map("created_at")

  booking   Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  question  CoachingPlanQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([bookingId, questionId])
  @@map("coaching_plan_answers")
}

// ==================== QUESTION CORE ====================

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  questions QuestionCategory[]

  @@map("categories")
}

model Question {
  id          Int          @id @default(autoincrement())
  title       String
  slug        String       @unique
  difficulty  Difficulty   @default(MEDIUM)
  type        QuestionType
  isPublished Boolean      @default(false) @map("is_published")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  categories   QuestionCategory[]
  companies    QuestionCompany[]
  jobRoles     QuestionJobRole[]
  bookmarks    UserBookmark[]
  mockSessions MockSessionQuestion[]

  // Polymorphic relations
  theoryQuestion TheoryQuestion?
  codingQuestion CodingQuestion?

  @@map("questions")
}

model TheoryQuestion {
  questionId Int  @id @map("question_id")
  data       Json // Cấu trúc json tự do cho trắc nghiệm / tự luận

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("theory_questions")
}

model CodingQuestion {
  questionId     Int     @id @map("question_id")
  description    String
  constraints    String?
  hints          String[]
  tags           String[]
  timeLimit      Int     @default(2000) @map("time_limit") // ms
  memoryLimit    Int     @default(256000) @map("memory_limit") // KB
  codeforcesLink String? @map("codeforces_link")

  question    Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  testCases   TestCase[]
  submissions CodeSubmission[]

  @@map("coding_questions")
}

// ---- Junction Tables cho Question ----

model QuestionCategory {
  questionId Int @map("question_id")
  categoryId Int @map("category_id")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([questionId, categoryId])
  @@map("question_categories")
}

model QuestionCompany {
  questionId Int @map("question_id")
  companyId  Int @map("company_id")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([questionId, companyId])
  @@map("question_companies")
}

model QuestionJobRole {
  questionId Int @map("question_id")
  jobRoleId  Int @map("job_role_id")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  jobRole  JobRole  @relation(fields: [jobRoleId], references: [id], onDelete: Cascade)

  @@id([questionId, jobRoleId])
  @@map("question_job_roles")
}

// ==================== CODING EXECUTION ====================

model TestCase {
  id               Int     @id @default(autoincrement())
  codingQuestionId Int     @map("coding_question_id")
  input            String
  expectedOutput   String  @map("expected_output")
  isSample         Boolean @default(false) @map("is_sample")
  isHidden         Boolean @default(false) // test ẩn hoàn toàn
  points           Float   @default(1)
  order            Int     @default(0)
  explanation      String? // giải thích khi sai

  codingQuestion CodingQuestion @relation(fields: [codingQuestionId], references: [questionId], onDelete: Cascade)

  @@unique([codingQuestionId, order])
  @@map("test_cases")
}

model CodeSubmission {
  id               Int              @id @default(autoincrement())
  userId           Int              @map("user_id")
  codingQuestionId Int              @map("coding_question_id")
  languageId       String           @map("language_id") // Judge0 language id: "63", "71", "54"
  language         String // display name: "javascript", "python"
  sourceCode       String           @map("source_code")
  status           SubmissionStatus @default(PENDING)
  verdict          String?
  score            Float?           @default(0)
  passedTestCases  Int?             @map("passed_test_cases")
  totalTestCases   Int?             @map("total_test_cases")
  executionTime    Float?           @map("execution_time") // ms
  memoryUsed       Int?             @map("memory_used") // KB
  errorMessage     String?          @map("error_message")
  submittedAt      DateTime         @default(now()) @map("submitted_at")
  judgedAt         DateTime?        @map("judged_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  codingQuestion CodingQuestion @relation(fields: [codingQuestionId], references: [questionId], onDelete: Cascade)

  @@map("code_submissions")
}

// ==================== SKILL ====================

model Skill {
  id   Int       @id @default(autoincrement())
  name String    @unique
  type SkillType

  userSkills UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId  Int        @map("user_id")
  skillId Int        @map("skill_id")
  experienceMonths Int        @map("experience_months") // Calculated by month
  level   SkillLevel
  proofUrl String? @map("proof_url")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

// ==================== INTERACTION & BOOKMARK ====================

model UserBookmark {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@map("user_bookmarks")
}

// ==================== MOCK SESSION ====================
model Match {
  id            Int           @id @default(autoincrement())

  candidateAId  Int           @map("candidate_a_id")
  candidateBId  Int           @map("candidate_b_id")

  status        MatchStatus   @default(WAITING)
  strategy      MatchStrategy

  matchScore    Float?        @map("match_score")

  matchedAt     DateTime?     @map("matched_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  candidateA User @relation("CandidateA", fields: [candidateAId], references: [id], onDelete: Cascade)
  candidateB User @relation("CandidateB", fields: [candidateBId], references: [id], onDelete: Cascade)

  mockSessions MockSession[]

  @@index([candidateAId, candidateBId])
  @@unique([candidateAId, candidateBId])
  @@map("matches")
}

model MockSession {
  id              Int           @id @default(autoincrement())

  bookingId       Int?          @map("booking_id")
  matchId         Int?          @map("match_id")

  intervieweeId   Int           @map("interviewee_id")

  scheduledAt     DateTime      @map("scheduled_at")
  durationMinutes Int           @map("duration_minutes")

  status          SessionStatus @default(SCHEDULED)

  recordingUrl    String?       @map("recording_url")
  meetingLink     String?       @map("meeting_link")

  startedAt       DateTime?
  endedAt         DateTime?

  source          SessionSource
  mode            SessionMode

  booking     Booking? @relation(fields: [bookingId], references: [id])
  match       Match?   @relation(fields: [matchId], references: [id])

  interviewee User @relation("IntervieweeSessions", fields: [intervieweeId], references: [id])

  soloSession SoloSession?
  meetSession MeetSession?

  feedbacks   Feedback[]
  questions   MockSessionQuestion[]

  @@map("mock_sessions")
}

model SoloSession {
  id        Int      @id @default(autoincrement())
  sessionId Int      @unique @map("session_id")
  script    Json?
  createdAt DateTime @default(now()) @map("created_at")

  session MockSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("solo_sessions")
}

model MeetSession {
  id        Int @id @default(autoincrement())
  sessionId Int @unique @map("session_id")

  session MockSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("meet_sessions")
}

model MockSessionQuestion {
  mockSessionId Int @map("mock_session_id")
  questionId    Int @map("question_id")

  mockSession MockSession @relation(fields: [mockSessionId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([mockSessionId, questionId])
  @@map("mock_session_questions")
}

model Feedback {
  id           Int      @id @default(autoincrement())
  sessionId    Int      @map("session_id")
  reviewerId   Int?     @map("reviewer_id")
  revieweeId   Int      @map("reviewee_id")
  strengths    Json?
  weaknesses   Json?
  suggestions  Json?
  overallScore Float    @map("overall_score")
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  session  MockSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reviewer User?        @relation("ReviewerFeedbacks", fields: [reviewerId], references: [id])
  reviewee User?        @relation("RevieweeFeedbacks", fields: [revieweeId], references: [id])

  @@map("feedbacks")
}

// ==================== PAYMENT ====================
model Payment {
  id                     Int      @id @default(autoincrement())
  bookingId              Int      @map("booking_id")

  amount                 Float
  currency               Currency

  provider               PaymentProvider
  providerTransactionId  String?  @map("provider_transaction_id")

  status                 PaymentStatus @default(PENDING)

  paymentUrl             String? @map("payment_url")

  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}