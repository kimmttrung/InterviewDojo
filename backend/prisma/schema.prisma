generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int               @id @default(autoincrement())
  email           String            @unique
  password        String
  name            String?
  bio             String?
  experienceYears Int               @default(0) @map("experience_years")
  status          String            @default("offline")
  avatarUrl       String?           @map("avatar_url")
  creditBalance   Float             @default(0.0) @map("credit_balance")
  createdAt       DateTime          @default(now()) @map("created_at")
  targetRoleId    Int?              @map("target_role_id")
  role            Role              @default(CANDIDATE)
  feedbacksGotten Feedback[]        @relation("RevieweeFeedbacks")
  feedbacksGiven  Feedback[]        @relation("ReviewerFeedbacks")
  isInterviewed   MockSession[]     @relation("IntervieweeSessions")
  interviews      MockSession[]     @relation("InterviewerSessions")
  attempts        QuestionAttempt[]
  soloRecordings  SoloRecording[]
  savedQuestions  UserBookmark[]
  skills          UserSkill[]
  targetRole      TargetRole?       @relation(fields: [targetRoleId], references: [id])
  bookings        Booking[]         @relation("CandidateBookings")

  mentorProfile MentorProfile?

  @@map("users")
}

model MentorProfile {
  id             Int            @id @default(autoincrement())
  userId         Int            @unique @map("user_id")
  cvUrl          String?        @map("cv_url")
  certificateUrl String?        @map("certificate_url")
  approvalStatus ApprovalStatus @default(PENDING) @map("approval_status")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilities Availability[]
  bookings       Booking[]      @relation("MentorBookings")

  @@map("mentor_profiles")
}

model TargetRole {
  id        Int                  @id @default(autoincrement())
  name      String               @unique
  questions TargetRoleQuestion[]
  users     User[]

  @@map("target_roles")
}

model Question {
  id           Int                  @id @default(autoincrement())
  createdAt    DateTime             @default(now()) @map("created_at")
  data         Json
  isPublished  Boolean              @default(false) @map("is_published")
  slug         String               @unique
  title        String
  typeQuestion TypeQuestion         @map("type_question")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  difficulty   Difficulty
  categories   CategoryQuestion[]
  sessions     MockSession[]
  attempts     QuestionAttempt[]
  companies    QuestionCompany[]
  targetRoles  TargetRoleQuestion[]
  savedByUsers UserBookmark[]

  @@map("questions")
}

model Category {
  id          Int                @id @default(autoincrement())
  name        String             @unique
  description String?
  questions   CategoryQuestion[]

  @@map("categories")
}

model CategoryQuestion {
  questionId Int      @map("question_id")
  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([questionId, categoryId])
  @@map("category_question")
}

model TargetRoleQuestion {
  targetRoleId Int        @map("target_role_id")
  questionId   Int        @map("question_id")
  question     Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  targetRole   TargetRole @relation(fields: [targetRoleId], references: [id], onDelete: Cascade)

  @@id([targetRoleId, questionId])
  @@map("target_role_question")
}

model UserBookmark {
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  savedAt    DateTime @default(now()) @map("saved_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, questionId])
  @@map("user_questions")
}

model QuestionAttempt {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  questionId Int      @map("question_id")
  status     String   @default("completed")
  score      Float?   @default(0)
  userAnswer Json?    @map("user_answer")
  duration   Int?
  createdAt  DateTime @default(now()) @map("created_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("question_attempts")
}

model Company {
  id        Int               @id @default(autoincrement())
  name      String            @unique
  logoUrl   String?           @map("logo_url")
  questions QuestionCompany[]

  @@map("companies")
}

model QuestionCompany {
  questionId Int      @map("question_id")
  companyId  Int      @map("company_id")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([questionId, companyId])
  @@map("question_companies")
}

model Skill {
  id       Int         @id @default(autoincrement())
  name     String      @unique
  category String?
  users    UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId  Int   @map("user_id")
  skillId Int   @map("skill_id")
  score   Float @default(0)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

model MockSession {
  id              Int         @id @default(autoincrement())
  interviewerId   Int         @map("interviewer_id")
  intervieweeId   Int         @map("interviewee_id")
  questionId      Int         @map("question_id")
  scheduledAt     DateTime    @default(now()) @map("scheduled_at")
  durationMinutes Int         @map("duration_minutes")
  status          String      @default("scheduled")
  recordingUrl    String?     @map("recording_url")
  meetingLink     String?     @map("meeting_link")
  aiAnalysis      AiAnalysis?
  feedbacks       Feedback[]
  interviewee     User        @relation("IntervieweeSessions", fields: [intervieweeId], references: [id])
  interviewer     User        @relation("InterviewerSessions", fields: [interviewerId], references: [id])
  question        Question    @relation(fields: [questionId], references: [id])

  @@map("mock_sessions")
}

model Feedback {
  id             Int         @id @default(autoincrement())
  sessionId      Int         @map("session_id")
  reviewerId     Int         @map("reviewer_id")
  revieweeId     Int         @map("reviewee_id")
  communication  Int
  technical      Int
  problemSolving Int         @map("problem_solving")
  comment        String?
  createdAt      DateTime    @default(now()) @map("created_at")
  reviewee       User        @relation("RevieweeFeedbacks", fields: [revieweeId], references: [id])
  reviewer       User        @relation("ReviewerFeedbacks", fields: [reviewerId], references: [id])
  session        MockSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

model AiAnalysis {
  id              Int  @id @default(autoincrement())
  sessionId       Int? @unique @map("session_id")
  soloRecordingId Int? @unique @map("solo_recording_id")

  transcript   String?
  strengths    Json?
  weaknesses   Json?
  suggestions  Json?
  overallScore Float    @map("overall_score")
  processedAt  DateTime @default(now()) @map("processed_at")

  session       MockSession?   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  soloRecording SoloRecording? @relation(fields: [soloRecordingId], references: [id], onDelete: Cascade)

  @@map("ai_analyses")
}

model SoloRecording {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  videoUrl  String   @map("video_url")
  publicId  String   @map("public_id")
  duration  Int?
  createdAt DateTime @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiAnalysis AiAnalysis?

  @@map("solo_recordings")
}

model Availability {
  id              Int      @id @default(autoincrement())
  mentorProfileId Int      @map("mentor_profile_id")
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  isBooked        Boolean  @default(false) @map("is_booked")
  createdAt       DateTime @default(now()) @map("created_at")

  mentor          MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

model Booking {
  id          Int           @id @default(autoincrement())
  mentorId    Int           @map("mentor_id")
  candidateId Int           @map("candidate_id")
  startTime   DateTime      @map("start_time")
  status      BookingStatus @default(PENDING)
  price       Float         @default(0.0)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  candidate   User          @relation("CandidateBookings", fields: [candidateId], references: [id])
  mentor      MentorProfile @relation("MentorBookings", fields: [mentorId], references: [id])

  @@map("bookings")
}

enum Role {
  CANDIDATE
  ADMIN
  MENTOR
  STAFF
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TypeQuestion {
  CODE
  BEHAVIORAL
  SYSTEM_DESIGN
  TECHNICAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

